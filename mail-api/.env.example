# mail-api/.env.example
# Skopiuj do mail-api/.env i uzupelnij wartosciami.
# Pelna lista produkcyjna jest w .env.production.example w katalogu glownym.

SMTP_HOST=s59.cyber-folks.pl
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

SMTP_FROM="Polskie Centrum Wizowe" <office@centrum-wizowe.pl>
CONTACT_EMAIL_TO=office@centrum-wizowe.pl

CORS_ORIGIN=https://www.centrum-wizowe.pl,https://centrum-wizowe.pl,http://localhost:3000

SITE_URL=http://localhost:3000
LOGO_URL=http://localhost:3000/logo-footer.svg

PORT=3001
NODE_ENV=development

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
