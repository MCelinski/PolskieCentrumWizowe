# mail-api/.env.example
# Skopiuj do mail-api/.env i uzupelnij wartosciami.
# Pelna lista produkcyjna jest w .env.production.example w katalogu glownym.

SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

SMTP_FROM="Polskie Centrum Wizowe" <biuro@twojadomena.pl>
CONTACT_EMAIL_TO=biuro@twojadomena.pl

CORS_ORIGIN=http://localhost:3000

SITE_URL=http://localhost:3000
LOGO_URL=http://localhost:3000/logo-footer.svg

PORT=3001
NODE_ENV=development

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
