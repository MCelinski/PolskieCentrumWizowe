# =============================================================================
# WSZYSTKIE KLUCZE PRODUKCYJNE - POLSKIE CENTRUM WIZOWE
# =============================================================================
# Ten plik jest szablonem. Skopiuj wartosci do GitHub Secrets albo do
# mail-api/.env na hostingu. Nie commituj prawdziwych hasel.
#
# A) GITHUB SECRETS - GitHub -> Settings -> Secrets and variables -> Actions
# B) SERWER API     - plik mail-api/.env na CyberFolks
# =============================================================================


# -----------------------------------------------------------------------------
# A) GITHUB SECRETS
# -----------------------------------------------------------------------------

SSH_HOST=sXXX.cyber-folks.pl
SSH_PORT=22
SSH_USER=twoj_login_ssh
SSH_PRIVATE_KEY=<zawartosc-prywatnego-klucza-ssh>

# Katalog domeny glownej, do ktorego trafia zawartosc out/
FRONTEND_PATH=/home/twoj_login/domains/polskiecentrumwizowe.pl/public_html

# Katalog aplikacji Node.js ustawiony w DirectAdmin jako Application root
API_PATH=/home/twoj_login/domains/api.polskiecentrumwizowe.pl/public_html/mail-api

# URL wbudowywany do statycznego frontendu podczas npm run build
NEXT_PUBLIC_API_URL=https://api.polskiecentrumwizowe.pl


# -----------------------------------------------------------------------------
# B) SERWER API - mail-api/.env
# -----------------------------------------------------------------------------

SMTP_HOST=mail.polskiecentrumwizowe.pl
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=biuro@polskiecentrumwizowe.pl
SMTP_PASS=TWOJE_HASLO_DO_SKRZYNKI

SMTP_FROM="Polskie Centrum Wizowe" <biuro@polskiecentrumwizowe.pl>
CONTACT_EMAIL_TO=biuro@polskiecentrumwizowe.pl

CORS_ORIGIN=https://polskiecentrumwizowe.pl

SITE_URL=https://polskiecentrumwizowe.pl
LOGO_URL=https://polskiecentrumwizowe.pl/logo-footer.svg

# Passenger zwykle sam ustawia PORT. Wartosc ponizej jest fallbackiem lokalnym.
PORT=3000
NODE_ENV=production

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
